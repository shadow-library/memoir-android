<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!--
        Exclude all encrypted credential stores from cloud backup.
        EncryptedSharedPreferences keys are device-bound; the ciphertext is
        useless on another device and should not leave this one.
    -->
    <exclude domain="sharedpref" path="memoir_firebase_config.xml" />
</full-backup-content>
